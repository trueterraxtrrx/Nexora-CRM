# Production environment variables
DB_HOST=db
DB_PORT=5432
DB_NAME=crm_db
DB_USER=crm_user
DB_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD
DB_POOL_SIZE=20

# REDIS
REDIS_HOST=redis
REDIS_PORT=6379

# JWT — MUST CHANGE!
JWT_SECRET=CHANGE_ME_TO_32_CHAR_RANDOM_STRING
JWT_EXPIRY_HOURS=24

# Server
PORT=8000
THREADS=8
DEBUG=false

# CORS
ALLOWED_ORIGINS=https://crm.yourdomain.com

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your_app_password

# Telegram
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN
# Project version: Nexora CRM V2.7









